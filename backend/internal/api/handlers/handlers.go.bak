package handlers

import (
	"fmt"
	"io"
	"log"
	"net/http"
	"os"
	"strconv"
	"strings"
	"time"

	"github.com/gin-gonic/gin"

	"railway-vless-panel/backend/internal/models"
	"railway-vless-panel/backend/internal/services"
)

// CreateConfigRequest is the request body for creating a config
type CreateConfigRequest struct {
	Remark      string `json:"remark" binding:"max=100"`
	Fingerprint string `json:"fingerprint"`
	HTTPVersion string `json:"http_version"`
	Path        string `json:"path"`
	Host        string `json:"host"`
	SNI         string `json:"sni"`
}

// Create creates a new configuration
func Create(c *gin.Context, cfgSvc *services.ConfigService) {
	var req CreateConfigRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	config, err := cfgSvc.Create(services.CreateConfigRequest{
		Remark:      req.Remark,
		Fingerprint: req.Fingerprint,
		HTTPVersion: req.HTTPVersion,
		Path:        req.Path,
		Host:        req.Host,
		SNI:         req.SNI,
	})
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusCreated, config.ToResponse())
}

// List returns all configurations
func List(c *gin.Context, cfgSvc *services.ConfigService) {
	configs, err := cfgSvc.List()
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}
	c.JSON(http.StatusOK, configs)
}

// Get returns a configuration by ID
func Get(c *gin.Context, cfgSvc *services.ConfigService) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 32)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid configuration ID"})
		return
	}

	config, err := cfgSvc.Get(uint(id))
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "Configuration not found"})
		return
	}

	c.JSON(http.StatusOK, config.ToResponse())
}

// Update updates a configuration
func Update(c *gin.Context, cfgSvc *services.ConfigService) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 32)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid configuration ID"})
		return
	}

	var req CreateConfigRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	config, err := cfgSvc.Update(uint(id), services.UpdateConfigRequest{
		Remark:      req.Remark,
		Fingerprint: req.Fingerprint,
		HTTPVersion: req.HTTPVersion,
		Path:        req.Path,
		Host:        req.Host,
		SNI:         req.SNI,
	})
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusOK, config.ToResponse())
}

// Delete deletes a configuration
func Delete(c *gin.Context, cfgSvc *services.ConfigService) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 32)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid configuration ID"})
		return
	}

	if err := cfgSvc.Delete(uint(id)); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusOK, gin.H{"message": "Configuration deleted"})
}

// GetStatus returns server status
func GetStatus(c *gin.Context, cfgSvc *services.ConfigService, xraySvc *services.XrayService) {
	// Get Xray status
	version, _ := xraySvc.GetVersion()
	running := xraySvc.IsRunning()
	uptime := xraySvc.GetUptime()
	pid := xraySvc.GetPID()

	// Get config count
	configs, _ := cfgSvc.List()
	configCount := len(configs)

	// Get system stats
	ramMB, cpuPercent := getSystemStats()

	domain := "localhost"
	port := "443"
	if cfgSvc.GetDomain() != "" {
		domain = cfgSvc.GetDomain()
	}
	if cfgSvc.GetPort() != "" {
		port = cfgSvc.GetPort()
	}

	c.JSON(http.StatusOK, gin.H{
		"running":      running,
		"xray_version": version,
		"domain":       domain,
		"port":         port,
		"config_count": configCount,
		"uptime":       uptime,
		"pid":          pid,
		"ram_usage":    fmt.Sprintf("%.0f MB", float64(ramMB)),
		"cpu_usage":    fmt.Sprintf("%.1f%%", cpuPercent),
		"timestamp":    time.Now().Unix(),
	})
}

// ReloadXray regenerates config and reloads Xray
func ReloadXray(c *gin.Context, xraySvc *services.XrayService) {
	if err := xraySvc.RegenerateConfig(); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusOK, gin.H{"message": "Xray configuration reloaded successfully"})
}

// GetVersion returns Xray version
func GetVersion(c *gin.Context, xraySvc *services.XrayService) {
	version, err := xraySvc.GetVersion()
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}
	c.JSON(http.StatusOK, gin.H{"version": version})
}

// GetConfigList returns formatted config list
func GetConfigList(c *gin.Context, cfgSvc *services.ConfigService) {
	configs, err := cfgSvc.List()
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	var responses []models.ConfigResponse
	for _, config := range configs {
		responses = append(responses, config.ToResponse())
	}

	if responses == nil {
		responses = []models.ConfigResponse{}
	}

	c.JSON(http.StatusOK, responses)
}

// GenerateURL generates VLESS URL for a config
func GenerateURL(c *gin.Context, cfgSvc *services.ConfigService) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 32)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid configuration ID"})
		return
	}

	config, err := cfgSvc.Get(uint(id))
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "Configuration not found"})
		return
	}

	c.JSON(http.StatusOK, gin.H{"url": cfgSvc.GenerateVlessURL(config)})
}

// GenerateJSON generates client config JSON
func GenerateJSON(c *gin.Context, cfgSvc *services.ConfigService) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 32)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "Invalid configuration ID"})
		return
	}

	config, err := cfgSvc.Get(uint(id))
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "Configuration not found"})
		return
	}

	c.JSON(http.StatusOK, cfgSvc.GenerateVlessJSON(config))
}

// getSystemStats reads system statistics from /proc
func getSystemStats() (ramMB uint64, cpuPercent float64) {
	ramMB = 0
	if data, err := readFile("/proc/meminfo"); err == nil {
		for _, line := range strings.Split(string(data), "\n") {
			if strings.HasPrefix(line, "MemAvailable:") {
				var kb uint64
				fmt.Sscanf(line, "MemAvailable: %d kB", &kb)
				ramMB = kb / 1024
				break
			}
		}
	}

	cpuPercent = 0.0
	if data, err := readFile("/proc/loadavg"); err == nil {
		var load1 float64
		fmt.Sscanf(string(data), "%f", &load1)
		cpuPercent = load1 / float64(os.Getpid()) * 100.0
		if cpuPercent > 100 {
			cpuPercent = 100
		}
	}

	return ramMB, cpuPercent
}

func readFile(path string) ([]byte, error) {
	f, err := os.Open(path)
	if err != nil {
		return nil, err
	}
	defer f.Close()
	return io.ReadAll(f)
}